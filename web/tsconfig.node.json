{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "target": "ES2023",
    "lib": [
      "ES2023"
    ],
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true,
    "moduleDetection": "force"
  },
  "include": [
    "vite.config.ts"
  ]
}
