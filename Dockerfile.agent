FROM golang:1.24.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/cfscan-agent ./cmd/agent

FROM alpine:3.22
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/cfscan-agent /usr/local/bin/cfscan-agent
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/cfscan-agent"]
