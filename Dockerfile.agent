FROM golang:1.26.5-alpine AS build
ARG VERSION=dev
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w -X main.version=${VERSION}" -o /out/cfscan-agent ./cmd/agent

FROM alpine:3.24
RUN apk add --no-cache ca-certificates tzdata
RUN mkdir -p /var/lib/cfscan-agent && chown 65532:65532 /var/lib/cfscan-agent
ENV CFSCAN_AGENT_IDENTITY_FILE=/var/lib/cfscan-agent/identity.json
COPY --from=build /out/cfscan-agent /usr/local/bin/cfscan-agent
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/cfscan-agent"]
