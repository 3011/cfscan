# Local development example. Do not reuse these values in production.

# Center
CFSCAN_HTTP_ADDR=:18080
# Host-side URL when PostgreSQL is started by compose.yaml (55432 -> 5432).
CFSCAN_DATABASE_URL=postgres://cfscan:cfscan@localhost:55432/cfscan?sslmode=disable
CFSCAN_AGENT_TOKEN=
# New Agent enrollment and generated deployment commands.
CFSCAN_PUBLIC_WEB_URL=http://localhost:18081
CFSCAN_PUBLIC_AGENT_URL=http://localhost:18080
CFSCAN_AGENT_IMAGE=ghcr.io/3011/cfscan-agent:v1.1.0
CFSCAN_AGENT_VERSION=v1.1.0
CFSCAN_AGENT_ENROLLMENT_TTL=10m
CFSCAN_AGENT_ENROLLMENT_POLL_INTERVAL=3s
CFSCAN_BOOTSTRAP_ADMIN_USERNAME=admin
CFSCAN_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-local-password
CFSCAN_SESSION_TTL=24h
# Local HTTP development must use false. Production HTTPS should use true.
CFSCAN_COOKIE_SECURE=false

# Agent
CFSCAN_CENTER_URL=http://localhost:18080
# Saved identities use this file. The legacy variables below are only needed during migration.
CFSCAN_AGENT_IDENTITY_FILE=.local/cfscan-agent/identity.json
CFSCAN_AGENT_NAME=local-agent
CFSCAN_AGENT_REGION=local
CFSCAN_AGENT_CONTINENT=local
CFSCAN_AGENT_CONCURRENCY=64
CFSCAN_AGENT_HEARTBEAT_INTERVAL=15s
CFSCAN_AGENT_POLL_INTERVAL=5s
